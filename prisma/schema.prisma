generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CommunityStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
}

enum MembershipStatus {
  PENDING
  APPROVED
}

enum InviteKind {
  NEW_COMMUNITY_OWNER
  COMMUNITY_MEMBER
}

enum ServiceRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String?
  isPlatformFounder Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invitesCreated InviteToken[] @relation("InviteCreator")
  inviteUsed     InviteToken?  @relation("InviteUsedBy")

  ownedCommunities Community[] @relation("CommunityOwner")

  communityMemberships CommunityMembership[]

  servicesOffered      Service[]          @relation("ServiceProvider")
  hireRequestsSent     ServiceRequest[]   @relation("Requester")
  hireRequestsReceived ServiceRequest[]   @relation("Provider")
}

model Community {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  status    CommunityStatus  @default(PENDING_APPROVAL)
  ownerId   String
  owner     User             @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  memberships  CommunityMembership[]
  services     Service[]
  inviteTokens InviteToken[]

  @@index([ownerId])
  @@index([status])
}

model CommunityMembership {
  id          String           @id @default(cuid())
  communityId String
  community   Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      MembershipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
}

model InviteToken {
  id          String     @id @default(cuid())
  token       String     @unique
  kind        InviteKind
  createdById String
  createdBy   User       @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  usedById    String?    @unique
  usedBy      User?      @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())

  @@index([createdById])
  @@index([communityId])
}

model Service {
  id          String   @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  providerId  String
  provider    User     @relation("ServiceProvider", fields: [providerId], references: [id], onDelete: Cascade)
  title       String
  description String
  priceLabel  String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests ServiceRequest[]

  @@index([communityId])
  @@index([providerId])
}

model ServiceRequest {
  id          String               @id @default(cuid())
  serviceId   String
  service     Service              @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User                 @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  providerId  String
  provider    User                 @relation("Provider", fields: [providerId], references: [id], onDelete: Cascade)
  message     String?
  status      ServiceRequestStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([serviceId])
  @@index([requesterId])
  @@index([providerId])
}
