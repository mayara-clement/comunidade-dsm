# PostgreSQL (ex.: Neon, Supabase, Vercel Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Obrigatório na Vercel (valor vazio = erro 500 no /api/auth).
# Gere com: openssl rand -base64 32   ou: npx auth secret
AUTH_SECRET="substitua-por-um-segredo-longo"

# Use a URL RAIZ do site, sem /api/auth no final.
# Produção: https://seu-projeto.vercel.app
AUTH_URL="http://localhost:3000"
# Alternativa (v4): NEXTAUTH_URL="http://localhost:3000"

AUTH_TRUST_HOST="1"

# Seed do fundador
FOUNDER_EMAIL="founder@example.com"
FOUNDER_PASSWORD="troque-esta-senha"
FOUNDER_NAME="Fundador"
