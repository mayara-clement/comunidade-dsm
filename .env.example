# PostgreSQL (ex.: Neon, Supabase, Vercel Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js v5: use AUTH_SECRET (obrigatório em produção)
# Gere com: openssl rand -base64 32
AUTH_SECRET="substitua-por-um-segredo-longo"

# URL pública do app (recomendado na v5: AUTH_URL)
AUTH_URL="http://localhost:3000"
# Compatível com tutoriais antigos:
# NEXTAUTH_URL="http://localhost:3000"

AUTH_TRUST_HOST="1"

# Seed do fundador
FOUNDER_EMAIL="founder@example.com"
FOUNDER_PASSWORD="troque-esta-senha"
FOUNDER_NAME="Fundador"
